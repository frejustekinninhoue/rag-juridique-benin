# Obtenez votre clé GRATUITE sur https://console.groq.com
# Groq offre ~14 000 requêtes/jour gratuitement avec Llama3
GROQ_API_KEY=votre_cle_groq_ici

# Nom du modèle Groq (gratuit)
GROQ_MODEL=llama-3.1-8b-instant

# Chemin de la base vectorielle
CHROMA_DB_PATH=./data/chroma_db

# Nombre de documents à récupérer par requête
TOP_K=5
